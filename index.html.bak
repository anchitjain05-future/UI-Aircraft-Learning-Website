<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Understanding the Airplane</title>
    <meta name="description" content="An interactive, beginner-friendly course to understand the physics and mechanics of airplanes.">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div id="app">
        <!-- Sidebar -->
        <aside id="sidebar">
            <div class="sidebar-header">
                <i data-lucide="plane-takeoff" class="logo-icon"></i>
                <h1>AeroLearn</h1>
            </div>
            <nav id="nav-menu">
                <!-- Navigation items injected via JS -->
            </nav>
        </aside>

        <!-- Main Content -->
        <main id="main-content">
            <header class="mobile-header">
                <button id="mobile-menu-btn"><i data-lucide="menu"></i></button>
                <h2>AeroLearn</h2>
            </header>

            <div class="content-wrapper" id="content-area">
                <!-- Content injected via JS -->
            </div>
        </main>
    </div>

    <!-- Physics Term Tooltip / Modal -->
    <div id="physics-tooltip" class="tooltip hidden">
        <h4 id="tooltip-title">Term</h4>
        <p id="tooltip-desc">Definition goes here.</p>
    </div>

    <script src="data.js"></script>
    <script src="data2.js"></script>
    <script src="data3.js"></script>
    <script src="data4.js"></script>
    <script src="data5.js"></script>
    <script src="data6.js"></script>
    <script src="app.js"></script>
</body>
</html>
